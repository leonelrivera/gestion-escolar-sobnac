# Configuración de Backup para Gestión Escolar SOBNAC
# Copia este archivo como 'backup.env' y completa los datos

# Directorio local de backups (en la VM)
BACKUP_DIR="/opt/backups/sgesoberanianacional/backups"

# Datos de la DB
DB_CONTAINER_NAME="postgres"
DB_USER="postgres"
DB_NAME="gestion_escolar_sobnac"

# Rclone (Remote:Carpeta)
GDRIVE_REMOTE="gdrive:/NombreDeTuCarpetaEnDrive"

# Nombre del servidor (para notificaciones)
SERVER_NAME="VM-SGE-SOBNAC"

# Telegram (Opcional pero recomendado)
TELEGRAM_BOT_TOKEN="123456789:ABCdefGHI..."
TELEGRAM_CHAT_ID="123456789"
